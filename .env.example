# =============================================================
# IWT Calendar — Environment Variables
# =============================================================
# Copy this to .env.local for local dev, or paste these into
# Vercel's Environment Variables panel for production.
# =============================================================

# ActiveCampaign API
# Find these in AC: Settings → Developer
# AC_API_URL looks like: https://YOURACCOUNT.api-us1.com
# AC_API_KEY is the long key on the same page
AC_API_URL=https://YOURACCOUNT.api-us1.com
AC_API_KEY=your_activecampaign_api_key_here

# AC tag IDs that grant calendar access
# These are already correct for IWT — don't change unless tags move
AC_TAG_ELITES=136
AC_TAG_PLATS=137

# Bootstrap admin emails (comma-separated, lowercased)
# These accounts always have admin access — cannot be locked out
BOOTSTRAP_ADMINS=joreymeljumayao.iwt@gmail.com

# JWT signing secret — generate any long random string
# Easy way: run `openssl rand -base64 32` or use https://generate-secret.vercel.app/32
JWT_SECRET=replace_with_long_random_string_at_least_32_chars

# Postgres database URL (auto-populated by Vercel when you add the integration)
# For local dev, use a Neon or Vercel Postgres connection string
POSTGRES_URL=postgres://...
